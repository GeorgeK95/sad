@Composable
private fun MomentumChart(
    modifier: Modifier,
    topBars: List<Float>,
    bottomBars: List<Float>,
    events: List<MomentumEvent>
) {
    Box(
        modifier = modifier
            .background(SurfaceBg, RoundedCornerShape(24.dp))
            .padding(12.dp)
    ) {
        Canvas(modifier = Modifier.fillMaxSize()) {
            val w = size.width
            val h = size.height
            val midY = h * 0.53f
            val leftPad = 18.dp.toPx()
            val rightPad = 10.dp.toPx()
            val topPad = 20.dp.toPx()
            val bottomPad = 18.dp.toPx()

            val chartW = w - leftPad - rightPad
            val chartTop = topPad
            val chartBottom = h - bottomPad
            val chartH = chartBottom - chartTop

            val dashed = PathEffect.dashPathEffect(floatArrayOf(8f, 8f), 0f)

            val minuteMarks = listOf(15, 30, 45, 60, 75, 90)
            minuteMarks.forEach { minute ->
                val x = leftPad + chartW * (minute / 95f)
                drawLine(
                    color = Grid,
                    start = Offset(x, chartTop),
                    end = Offset(x, chartBottom),
                    strokeWidth = 1.dp.toPx()
                )
            }

            val horizontalLevels = listOf(0.22f, 0.53f, 0.84f)
            horizontalLevels.forEach { yFactor ->
                val y = chartTop + chartH * yFactor
                drawLine(
                    color = Grid,
                    start = Offset(leftPad, y),
                    end = Offset(leftPad + chartW, y),
                    strokeWidth = 1.dp.toPx()
                )
            }

            drawLine(
                color = Grid,
                start = Offset(leftPad, midY),
                end = Offset(leftPad + chartW, midY),
                strokeWidth = 2.dp.toPx()
            )

            val groupCount = topBars.size
            val barGroupWidth = chartW / groupCount
            val barWidth = barGroupWidth * 0.72f
            val segmentCount = 7

            topBars.forEachIndexed { index, magnitude ->
                if (magnitude > 0f) {
                    val x = leftPad + index * barGroupWidth + (barGroupWidth - barWidth) / 2f
                    val totalHeight = magnitude * (midY - chartTop) * 0.92f
                    val segmentHeight = totalHeight / segmentCount
                    repeat(segmentCount) { seg ->
                        val segW = barWidth * (1f - seg * 0.08f)
                        val segX = x + (barWidth - segW) / 2f
                        val segY = midY - (seg + 1) * segmentHeight
                        drawRoundRect(
                            color = RedBar,
                            topLeft = Offset(segX, segY),
                            size = Size(segW, segmentHeight - 2.dp.toPx()),
                            cornerRadius = CornerRadius(4.dp.toPx(), 4.dp.toPx())
                        )
                    }
                }
            }

            bottomBars.forEachIndexed { index, magnitude ->
                if (magnitude > 0f) {
                    val x = leftPad + index * barGroupWidth + (barGroupWidth - barWidth) / 2f
                    val totalHeight = magnitude * (chartBottom - midY) * 0.92f
                    val segmentHeight = totalHeight / segmentCount
                    repeat(segmentCount) { seg ->
                        val segW = barWidth * (1f - seg * 0.08f)
                        val segX = x + (barWidth - segW) / 2f
                        val segY = midY + seg * segmentHeight
                        drawRoundRect(
                            color = GrayBar,
                            topLeft = Offset(segX, segY),
                            size = Size(segW, segmentHeight - 2.dp.toPx()),
                            cornerRadius = CornerRadius(4.dp.toPx(), 4.dp.toPx())
                        )
                    }
                }
            }

            drawRoundRect(
                color = AccentGreen,
                topLeft = Offset(leftPad + chartW - 3.dp.toPx(), chartTop),
                size = Size(3.dp.toPx(), chartBottom - chartTop),
                cornerRadius = CornerRadius(12f, 12f)
            )

            drawRoundRect(
                color = AccentGreen,
                topLeft = Offset(leftPad + chartW - 70.dp.toPx(), chartTop),
                size = Size(60.dp.toPx(), 28.dp.toPx()),
                cornerRadius = CornerRadius(20.dp.toPx(), 20.dp.toPx())
            )

            events.forEach { event ->
                val x = leftPad + chartW * (event.minute / 95f)
                val y = midY - ((midY - chartTop) * event.level.coerceIn(-1f, 1f) * 0.9f)

                val bgColor = when (event.type) {
                    EventType.GOAL, EventType.PENALTY_GOAL -> Color(0xFF1F8F74)
                    EventType.OWN_GOAL, EventType.PENALTY_MISS, EventType.RED_CARD -> Color(0xFF7A3B3B)
                    EventType.SUBSTITUTION -> Color(0xFF4D5E93)
                }

                drawRoundRect(
                    color = bgColor,
                    topLeft = Offset(x - 16.dp.toPx(), y - 12.dp.toPx()),
                    size = Size(32.dp.toPx(), 24.dp.toPx()),
                    cornerRadius = CornerRadius(10.dp.toPx(), 10.dp.toPx())
                )

                val icon = when (event.type) {
                    EventType.GOAL -> "⚽"
                    EventType.OWN_GOAL -> "🥅"
                    EventType.PENALTY_GOAL -> "⚽"
                    EventType.PENALTY_MISS -> "❌"
                    EventType.RED_CARD -> "🟥"
                    EventType.SUBSTITUTION -> "🔄"
                }

                drawContext.canvas.nativeCanvas.apply {
                    drawText(
                        icon,
                        x,
                        y + 6.dp.toPx(),
                        android.graphics.Paint().apply {
                            color = android.graphics.Color.WHITE
                            textAlign = android.graphics.Paint.Align.CENTER
                            textSize = 14.sp.toPx()
                            isAntiAlias = true
                        }
                    )
                }
            }

            drawRoundRect(
                color = Color(0xFFA21212),
                topLeft = Offset(leftPad + chartW * (44f / 95f) - 18.dp.toPx(), midY - 10.dp.toPx()),
                size = Size(36.dp.toPx(), 24.dp.toPx()),
                cornerRadius = CornerRadius(12.dp.toPx(), 12.dp.toPx())
            )

            drawContext.canvas.nativeCanvas.apply {
                val smallPaint = android.graphics.Paint().apply {
                    color = android.graphics.Color.parseColor("#EDEDED")
                    textAlign = android.graphics.Paint.Align.CENTER
                    textSize = 14.sp.toPx()
                    isAntiAlias = true
                    isFakeBoldText = true
                }

                minuteMarks.forEach { minute ->
                    val x = leftPad + chartW * (minute / 95f)
                    drawText(
                        if (minute == 90) "90+5'" else "$minute'",
                        x,
                        chartTop - 6.dp.toPx(),
                        smallPaint
                    )
                }

                drawText(
                    "HT",
                    leftPad + chartW * (45f / 95f),
                    midY + 7.dp.toPx(),
                    smallPaint
                )
            }

            drawRoundRect(
                color = Grid.copy(alpha = 0.5f),
                topLeft = Offset(leftPad, chartTop),
                size = Size(chartW, chartBottom - chartTop),
                cornerRadius = CornerRadius(22.dp.toPx(), 22.dp.toPx()),
                style = Stroke(width = 1.dp.toPx(), pathEffect = dashed)
            )
        }
    }
}

@Composable
private fun Legend() {
    val items = listOf(
        "⚽ Goal" to null,
        "🥅 Own Goal" to null,
        "⚽ Penalty goal" to AccentGreen,
        "❌ Penalty miss" to AccentGreen,
        "🟥 Red card" to null,
        "🔄 Substitution" to null
    )

    FlowRow(
        horizontalArrangement = Arrangement.spacedBy(10.dp),
        verticalArrangement = Arrangement.spacedBy(10.dp)
    ) {
        items.forEach { (label, underlineColor) ->
            LegendChip(label, underlineColor)
        }
    }
}

@Composable
private fun LegendChip(
    text: String,
    underlineColor: Color?
) {
    Column {
        Box(
            modifier = Modifier
                .background(SurfaceBg, RoundedCornerShape(50))
                .padding(horizontal = 14.dp, vertical = 10.dp)
        ) {
            Text(
                text = text,
                color = TextPrimary,
                fontSize = 14.sp,
                fontWeight = FontWeight.Medium,
                textAlign = TextAlign.Center
            )
        }

        if (underlineColor != null) {
            Spacer(
                modifier = Modifier
                    .padding(horizontal = 18.dp)
                    .height(2.dp)
                    .fillMaxWidth()
                    .background(underlineColor, RoundedCornerShape(10.dp))
            )
        }
    }
}

