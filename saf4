enum class EventType {
    GOAL,
    OWN_GOAL,
    PENALTY_GOAL,
    PENALTY_MISS,
    RED_CARD,
    SUBSTITUTION
}

data class MomentumEvent(
    val minute: Float,
    val level: Float, // + is home, - is away
    val type: EventType
)

