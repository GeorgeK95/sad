    modifier: Modifier,
    badgeColor: Color,
    badgeText: String,
    teamName: String,
    side: String,
    alignStart: Boolean
) {
    Row(
        modifier = modifier,
        horizontalArrangement = if (alignStart) Arrangement.Start else Arrangement.End,
        verticalAlignment = Alignment.CenterVertically
    ) {
        if (alignStart) {
            TeamBadge(badgeColor, badgeText)
            Spacer(Modifier.width(12.dp))
