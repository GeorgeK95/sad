data class LegendItem(
    val label: String,
    val content: @Composable () -> Unit
)

@Composable
fun MatchLegend(
    modifier: Modifier = Modifier
) {
    val items = listOf(
        LegendItem("Goal") {
            Icon(
                imageVector = Icons.Default.Circle,
                contentDescription = null,
                tint = Color.White,
                modifier = Modifier.size(18.dp)
            )
        },
        LegendItem("Own Goal") {
            Icon(
                imageVector = Icons.Default.Circle,
                contentDescription = null,
                tint = Color(0xFFFF6B6B),
                modifier = Modifier.size(18.dp)
            )
        },
        LegendItem("Penalty goal") {
            Row(horizontalArrangement = Arrangement.spacedBy(2.dp)) {
                Icon(
                    imageVector = Icons.Default.Circle,
                    contentDescription = null,
                    tint = Color.White,
                    modifier = Modifier.size(18.dp)
                )
                Text(
                    text = "•",
                    color = Color(0xFF72F1B8),
                    style = MaterialTheme.typography.bodySmall
                )
            }
        },
        LegendItem("Penalty miss") {
            Icon(
                imageVector = Icons.Default.Close,
                contentDescription = null,
                tint = Color(0xFFFF8A80),
                modifier = Modifier.size(18.dp)
            )
        },
        LegendItem("Red card") {
            Surface(
                modifier = Modifier.size(width = 12.dp, height = 18.dp),
                color = Color(0xFFFF5A5A),
                shape = RoundedCornerShape(3.dp)
            ) {}
        },
        LegendItem("Substitution") {
            Row(horizontalArrangement = Arrangement.spacedBy(2.dp)) {
                Icon(
                    imageVector = Icons.Default.KeyboardArrowDown,
                    contentDescription = null,
                    tint = Color(0xFFFF7A7A),
                    modifier = Modifier.size(18.dp)
                )
                Icon(
                    imageVector = Icons.Default.KeyboardArrowUp,
                    contentDescription = null,
                    tint = Color(0xFF72F1B8),
                    modifier = Modifier.size(18.dp)
                )
            }
        }
    )

    FlowRow(
        modifier = modifier,
        horizontalArrangement = Arrangement.spacedBy(12.dp),
        verticalArrangement = Arrangement.spacedBy(12.dp)
    ) {
        items.forEach { item ->
            LegendChip(
                label = item.label,
                leadingContent = item.content
            )
        }
    }
}

@Composable
fun LegendChip(
    label: String,
    leadingContent: @Composable () -> Unit,
    modifier: Modifier = Modifier
) {
    Row(
        modifier = modifier
            .clip(RoundedCornerShape(20.dp))
            .background(Color(0xFF3A3F46))
            .border(
                width = 1.dp,
                color = Color(0xFF8E98A3),
                shape = RoundedCornerShape(20.dp)
            )
            .padding(horizontal = 14.dp, vertical = 10.dp),
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        leadingContent()

        Text(
            text = label,
            color = Color.White,
            style = MaterialTheme.typography.bodyMedium.copy(
                fontWeight = FontWeight.SemiBold
            )
        )
    }
}