@Composable
fun MomentumChart(
    modifier: Modifier = Modifier,
    timeLabels: List<String>,
    currentMinute: Int = 0,
    momentumEvents: List<MomentumEvent> = emptyList(),
    minuteValues: Map<Int, Float> = emptyMap(),
    lineColor: Color = FollowScoresTheme.colors.contentVariant,
    lineWidth: Float = 2f,
    textColor: Color = FollowScoresTheme.colors.contentVariant,
    textSize: Float = 32f,
    currentMinuteColor: Color = FollowScoresTheme.colors.contentDark,
    currentMinuteIndicatorColor: Color = FollowScoresTheme.colors.primary,
    connectionLineLength: Float = 50f,
    connectionLineColor: Color = FollowScoresTheme.colors.contentVariant,
    addedTimeBlurColor: Color = FollowScoresTheme.colors.contentVariant.copy(alpha = 0.2f),
    momentumLineColor: Color = Color(0xFFFFC107),
    momentumLineWidth: Float = 1.5f,
    momentumMaxAbsValue: Float = 100f,
    onEventClick: (MomentumEvent) -> Unit = {},
    onDismiss: () -> Unit = {}
) {
    val context = LocalContext.current
    val iconPositions = remember { mutableStateMapOf<MomentumEvent, Rect>() }

    Canvas(
        modifier = modifier
            .fillMaxWidth()
            .height(200.dp)
            .padding(vertical = 10.dp)
            .pointerInput(momentumEvents) {
                detectTapGestures { offset ->
                    var iconClicked = false
                    iconPositions.forEach { (event, rect) ->
                        if (rect.contains(offset)) {
                            onEventClick(event)
                            iconClicked = true
                            return@forEach
                        }
                    }
                    if (!iconClicked) {
                        onDismiss()
                    }
                }
            }
    ) {
        val canvasWidth = size.width
        val canvasHeight = size.height

        val maxMinutes = if (timeLabels.isNotEmpty()) {
            timeLabels.last().replace("'", "").toIntOrNull() ?: 90
        } else {
            90
        }

        val clampedCurrentMinute = currentMinute.coerceIn(0, maxMinutes)

        iconPositions.clear()

        val horizontalSpacing = canvasHeight / 4f
        val middleY = canvasHeight / 2f

        // Important:
        // top half = [0 .. middleY]
        // bottom half = [middleY .. canvasHeight]
        // so the maximum possible excursion from center is canvasHeight / 2.
        // We keep some padding so the line does not touch top/bottom.
        val halfChartHeight = canvasHeight / 2f
        val momentumAmplitude = halfChartHeight * 0.82f

        val textPaint = Paint().apply {
            color = textColor.toArgb()
            textAlign = Paint.Align.CENTER
            this.textSize = textSize
            isFakeBoldText = true
        }

        val minuteTextPaint = Paint().apply {
            color = currentMinuteColor.toArgb()
            textAlign = Paint.Align.CENTER
            this.textSize = 24f
            isFakeBoldText = true
        }

        fun minuteToX(minute: Int): Float {
            return (minute / maxMinutes.toFloat()) * canvasWidth
        }

        // Vertical time lines + labels
        timeLabels.forEach { label ->
            val minute = label.replace("'", "").toIntOrNull()
            if (minute != null) {
                val x = minuteToX(minute)

                drawLine(
                    color = lineColor,
                    start = Offset(x, 0f),
                    end = Offset(x, canvasHeight),
                    strokeWidth = lineWidth
                )

                drawContext.canvas.nativeCanvas.drawText(
                    label,
                    x,
                    -10f,
                    textPaint
                )
            }
        }

        // Horizontal lines
        for (i in 0..4) {
            val y = i * horizontalSpacing
            val isMiddleLine = i == 2

            drawLine(
                color = lineColor,
                start = Offset(0f, y),
                end = Offset(canvasWidth, y),
                strokeWidth = if (isMiddleLine) lineWidth * 2f else lineWidth
            )
        }

        // Momentum line
        drawMomentumProgressLine(
            minuteValues = minuteValues,
            currentMinute = clampedCurrentMinute,
            maxMinutes = maxMinutes,
            canvasWidth = canvasWidth,
            middleY = middleY,
            amplitude = momentumAmplitude,
            maxAbsValue = momentumMaxAbsValue,
            lineColor = momentumLineColor,
            lineWidthPx = momentumLineWidth.dp.toPx()
        )

        // Events
        drawMomentumEvents(
            context = context,
            momentumEvents = momentumEvents,
            maxMinutes = maxMinutes,
            canvasWidth = canvasWidth,
            minuteValues = minuteValues,
            maxBarHeight = momentumAmplitude,
            middleY = middleY,
            connectionLineLength = connectionLineLength,
            connectionLineColor = connectionLineColor,
            lineWidth = lineWidth,
            iconPositions = iconPositions,
            textColor = textColor
        )

        // HT
        val htMinute = 45
        if (htMinute <= maxMinutes) {
            val htX = minuteToX(htMinute)
            drawContext.canvas.nativeCanvas.drawText(
                "HT",
                htX,
                canvasHeight + textSize + 10f,
                textPaint
            )
        }

        // Current minute indicator
        val currentX = minuteToX(clampedCurrentMinute)
        drawLine(
            color = currentMinuteIndicatorColor,
            start = Offset(currentX, 0f),
            end = Offset(currentX, canvasHeight),
            strokeWidth = lineWidth * 2f
        )

        val boxWidth = 60f
        val boxHeight = 40f
        val boxTop = -40f
        val cornerRadius = 8.dp.toPx()

        drawRoundRect(
            color = currentMinuteIndicatorColor,
            topLeft = Offset(currentX - boxWidth / 2f, boxTop),
            size = Size(boxWidth, boxHeight),
            cornerRadius = CornerRadius(cornerRadius, cornerRadius)
        )

        drawContext.canvas.nativeCanvas.drawText(
            "$clampedCurrentMinute '",
            currentX,
            boxTop + boxHeight / 2f + 8f,
            minuteTextPaint
        )
    }
}

private fun DrawScope.drawMomentumProgressLine(
    minuteValues: Map<Int, Float>,
    currentMinute: Int,
    maxMinutes: Int,
    canvasWidth: Float,
    middleY: Float,
    amplitude: Float,
    maxAbsValue: Float,
    lineColor: Color,
    lineWidthPx: Float
) {
    if (minuteValues.isEmpty()) return

    val visibleEntries = minuteValues
        .toSortedMap()
        .filterKeys { it in 0..currentMinute }

    if (visibleEntries.isEmpty()) return

    val safeMaxAbsValue = maxAbsValue
        .takeIf { it > 0f }
        ?: 1f

    fun minuteToX(minute: Int): Float {
        return (minute / maxMinutes.toFloat()) * canvasWidth
    }

    fun valueToY(value: Float): Float {
        val normalized = (value / safeMaxAbsValue).coerceIn(-1f, 1f)
        return middleY - (normalized * amplitude)
    }

    val points = visibleEntries.map { (minute, value) ->
        Offset(
            x = minuteToX(minute),
            y = valueToY(value)
        )
    }

    if (points.isEmpty()) return

    if (points.size == 1) {
        drawCircle(
            color = lineColor,
            radius = lineWidthPx,
            center = points.first()
        )
        return
    }

    val path = Path().apply {
        moveTo(points.first().x, points.first().y)

        for (i in 1 until points.size) {
            val prev = points[i - 1]
            val curr = points[i]

            val midX = (prev.x + curr.x) / 2f
            val midY = (prev.y + curr.y) / 2f

            quadraticBezierTo(
                prev.x,
                prev.y,
                midX,
                midY
            )
        }

        lineTo(points.last().x, points.last().y)
    }

    drawPath(
        path = path,
        color = lineColor,
        style = Stroke(
            width = lineWidthPx,
            cap = StrokeCap.Round,
            join = StrokeJoin.Round
        )
    )
}
